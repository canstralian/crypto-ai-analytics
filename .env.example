# Application Environment Variables
# Copy this file to .env and fill in your actual values

# Environment
ENVIRONMENT=development

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crypto_ai
DATABASE_POOL_SIZE=20
DATABASE_POOL_OVERFLOW=10

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_POOL_SIZE=10

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=crypto-ai-analytics
KAFKA_AUTO_OFFSET_RESET=earliest

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
BCRYPT_ROUNDS=12

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME="Crypto AI Analytics"
VERSION=1.0.0
DEBUG=true
LOG_LEVEL=debug

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"]
CORS_ALLOW_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# External API Keys (Exchange APIs)
BINANCE_API_KEY=your-binance-api-key
BINANCE_SECRET_KEY=your-binance-secret-key

COINBASE_API_KEY=your-coinbase-api-key
COINBASE_SECRET_KEY=your-coinbase-secret-key

KRAKEN_API_KEY=your-kraken-api-key
KRAKEN_SECRET_KEY=your-kraken-secret-key

# Social Media APIs
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-twitter-access-token-secret

REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=crypto-ai-analytics/1.0

# News APIs
NEWS_API_KEY=your-news-api-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key

# Messaging APIs
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
DISCORD_BOT_TOKEN=your-discord-bot-token

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true
SMTP_SSL=false

# AWS Configuration (for production)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-west-2
S3_BUCKET_NAME=crypto-ai-analytics-data

# ML Model Configuration
MODEL_STORAGE_PATH=./models
MODEL_CACHE_SIZE=100
TORCH_SERVE_URL=http://localhost:8080
ENABLE_GPU=false

# Monitoring
SENTRY_DSN=your-sentry-dsn
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Frontend URLs
FRONTEND_URL=http://localhost:3000
WEBSOCKET_URL=ws://localhost:8000/ws

# File Upload
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_FILE_TYPES=["image/jpeg", "image/png", "text/csv", "application/json"]

# Session Configuration
SESSION_EXPIRE_HOURS=168  # 7 days
REMEMBER_ME_EXPIRE_DAYS=30

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=["json"]
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true

# Background Tasks
PRICE_UPDATE_INTERVAL=60  # seconds
SENTIMENT_ANALYSIS_INTERVAL=300  # 5 minutes
MODEL_TRAINING_SCHEDULE="0 2 * * *"  # Daily at 2 AM
DATA_CLEANUP_SCHEDULE="0 3 * * 0"  # Weekly on Sunday at 3 AM

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PASSWORD_RESET=true
ENABLE_2FA=false
ENABLE_SOCIAL_LOGIN=true
ENABLE_API_DOCS=true
ENABLE_METRICS_ENDPOINT=true

# Development
RELOAD_ON_CHANGE=true
SHOW_SQL_QUERIES=false